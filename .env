# Camera Node Configuration
CLIENT_ID=melb-01-cam-01
HTTP_PORT=8080

# Recording Settings
SEGMENT_SECS=120
SESSION_DIR=/home/pi/recordings
RECORD_BITRATE=6000000
RECORD_WIDTH=1280
RECORD_HEIGHT=720
RECORD_FPS=30

# Streaming Settings
STREAM_ENABLED=true
STREAM_TARGET_IP=192.168.8.145
STREAM_TARGET_PORT=5000
STREAM_BITRATE=600000
STREAM_WIDTH=480
STREAM_HEIGHT=270

# Sync Settings (rsync daemon mode)
SYNC_ENABLED=true
SYNC_TARGET_HOST=192.168.8.145
SYNC_MODULE=logging

# MQTT Logging
MQTT_BROKER=192.168.8.145
MQTT_TOPIC_BASE=logging/melb-01-cam-01/

# Device
DEVICE=/dev/video0
